# ===========================
# Database
# ===========================
# PostgreSQL (Production)
DATABASE_URL="postgresql://user:password@localhost:5432/cashier_db"

# SQLite (Development / Offline)
# DATABASE_URL="file:./dev.db"

# ===========================
# NextAuth.js
# ===========================
# أنشئ القيمة بـ: openssl rand -base64 64 (يجب 64 حرف على الأقل)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ===========================
# Encryption (للنسخ الاحتياطي)
# ===========================
# أنشئ القيمة بـ: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=""

# ===========================
# Rate Limiting — Upstash Redis (اختياري في الإنتاج)
# ===========================
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ===========================
# App Settings
# ===========================
NEXT_PUBLIC_APP_NAME="نظام الكاشير"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ===========================
# Store Info (for receipts)
# ===========================
NEXT_PUBLIC_STORE_NAME="اسم المحل التجاري"
NEXT_PUBLIC_STORE_ADDRESS="عنوان المحل"
NEXT_PUBLIC_STORE_PHONE="0501234567"
NEXT_PUBLIC_STORE_VAT="123456789"
