    "db:seed": "npm run db:backup && ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "npm run db:backup && prisma migrate reset --force"
  },
